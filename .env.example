# Analytics Configuration
# Uncomment and add your Google Analytics tracking ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Billing Configuration
# Set these to your checkout and billing portal URLs once your provider is ready.
# VITE_CHECKOUT_URL_PLUS=https://...
# VITE_CHECKOUT_URL_PRO=https://...
# VITE_BILLING_PORTAL_URL=https://...

# Server-side secrets (set in Supabase edge function runtime/hosting secrets)
# BILLING_WEBHOOK_SECRET=...
# SUPABASE_SERVICE_ROLE_KEY=...

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Add other environment variables as needed
